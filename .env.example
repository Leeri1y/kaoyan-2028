# Render 部署时无需手动设置，由 render.yaml 自动注入（数据库连接串来自
# render.yaml 里声明的 kaoyan-2028-db，Render 会自动创建免费 Postgres 并
# 把 DATABASE_URL 注入进来，不需要手动去后台配置）
PORT=3000
API_PUBLIC_URL=https://kaoyan-2028.onrender.com

# 本地开发时需要自己起一个 Postgres（比如 `docker run -p 5432:5432
# -e POSTGRES_PASSWORD=postgres postgres:16`），然后填这里：
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kaoyan2028

# 简单的访问令牌，用于给写操作加一层门槛（详见 server.js 里的说明）。
# 需要在 Render 后台的环境变量里也设置同样的值，并把它填到
# public/js/config.js 的 window.APP_TOKEN 里，两边必须一致。
# 留空则不做任何校验（本地开发默认行为）。
APP_TOKEN=
