PORT=3000
API_PUBLIC_URL=https://kaoyan-2028.onrender.com

# 数据库用的是 Neon（免费 Postgres，永久不过期，注册地址 neon.tech）。
# 之前用过 Render 自带的免费 Postgres，但那个 30 天就会过期、
# 到期不续费直接删库删数据，所以换掉了。
#
# 线上（Render）：去 Render 后台 → kaoyan-2028 服务 → Environment，
# 手动加一个 DATABASE_URL，值填 Neon 项目控制台里的 Connection string
# （类似 postgresql://用户:密码@ep-xxxx.aws.neon.tech/neondb?sslmode=require）。
# render.yaml 里这一项标了 sync: false，就是提醒"这个要手动填，不会自动生成"。
#
# 本地开发：去 neon.tech 控制台新建一个项目（或者复用同一个线上项目），
# 复制它的 Connection string 填在下面：
DATABASE_URL=postgresql://用户:密码@ep-xxxx.aws.neon.tech/neondb?sslmode=require

# 简单的访问令牌，用于给写操作加一层门槛（详见 server.js 里的说明）。
# 需要在 Render 后台的环境变量里也设置同样的值，并把它填到
# public/js/config.js 的 window.APP_TOKEN 里，两边必须一致。
# 留空则不做任何校验（本地开发默认行为）。
APP_TOKEN=
